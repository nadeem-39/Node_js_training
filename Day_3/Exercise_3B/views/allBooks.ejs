<!DOCTYPE html>
<html>
<head>
    <title>Book Management</title>

    <style>

        body{
            font-family: Arial;
            padding: 20px;
        }

        table{
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th,td{
            border: 1px solid black;
            padding: 10px;
            text-align: center;
        }

        button{
            padding: 6px 12px;
            cursor: pointer;
        }

        .popup{
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);

            justify-content: center;
            align-items: center;
        }

        .popup-content{
            background: white;
            padding: 20px;
            width: 350px;
            border-radius: 10px;
        }

        input{
            width: 100%;
            padding: 8px;
            margin-top: 10px;
        }

        .close-btn{
            float: right;
            background: red;
            color: white;
            border: none;
        }

    </style>
</head>

<body>

    <h1>Book Management</h1>

    <button onclick="openAddPopup()">
        Add Book
    </button>

    <table>

        <thead>

            <tr>

                <th>BookId</th>
                <th>BookName</th>
                <th>Author</th>
                <th>Price</th>
                <th>Pages</th>
                <th>Actions</th>

            </tr>

        </thead>

        <tbody id="bookTableBody">

            <% books.forEach((book)=> { %>

                <tr id="row-<%= book.BookId %>">

                    <td><%= book.BookId %></td>

                    <td><%= book.BookName %></td>

                    <td><%= book.Author %></td>

                    <td><%= book.Price %></td>

                    <td><%= book.Pages %></td>

                    <td>

                        <button
                            onclick='openViewPopup(
                                "<%= book.BookId %>",
                                "<%= book.BookName %>",
                                "<%= book.Author %>",
                                "<%= book.Price %>",
                                "<%= book.Pages %>"
                            )'
                        >
                            View
                        </button>

                        <button
                            onclick='openEditPopup(
                                "<%= book.BookId %>",
                                "<%= book.BookName %>",
                                "<%= book.Author %>",
                                "<%= book.Price %>",
                                "<%= book.Pages %>"
                            )'
                        >
                            Edit
                        </button>

                        <button
                            onclick='deleteBook(
                                "<%= book.BookId %>"
                            )'
                        >
                            Delete
                        </button>

                    </td>

                </tr>

            <% }) %>

        </tbody>

    </table>



    <!-- Popup -->

    <div class="popup" id="popup">

        <div class="popup-content">

            <button
                class="close-btn"
                onclick="closePopup()"
            >
                X
            </button>

            <h2 id="popupTitle">
                Add Book
            </h2>

            <form id="bookForm">

                <input
                    type="number"
                    id="BookId"
                    placeholder="Book Id"
                    required
                >

                <input
                    type="text"
                    id="BookName"
                    placeholder="Book Name"
                    required
                >

                <input
                    type="text"
                    id="Author"
                    placeholder="Author"
                    required
                >

                <input
                    type="number"
                    id="Price"
                    placeholder="Price"
                    required
                >

                <input
                    type="number"
                    id="Pages"
                    placeholder="Pages"
                    required
                >

                <br><br>

                <button type="submit" id="submitBtn">
                    Submit
                </button>

            </form>

        </div>

    </div>



    <script>

        const popup =
            document.getElementById("popup");

        const form =
            document.getElementById("bookForm");

        const tableBody =
            document.getElementById(
                "bookTableBody"
            );

        let editMode = false;

        let currentBookId = null;



        // Add Popup

        function openAddPopup(){

            popup.style.display = "flex";

            document.getElementById(
                "popupTitle"
            ).innerText = "Add Book";

            form.reset();

            enableInputs(true);

            document.getElementById(
                "submitBtn"
            ).style.display = "block";

            editMode = false;
        }



        // Edit Popup

        function openEditPopup(
            BookId,
            BookName,
            Author,
            Price,
            Pages
        ){

            popup.style.display = "flex";

            document.getElementById(
                "popupTitle"
            ).innerText = "Edit Book";

            setValues(
                BookId,
                BookName,
                Author,
                Price,
                Pages
            );

            enableInputs(true);

            document.getElementById(
                "submitBtn"
            ).style.display = "block";

            editMode = true;

            currentBookId = BookId;
        }



        // View Popup

        function openViewPopup(
            BookId,
            BookName,
            Author,
            Price,
            Pages
        ){

            popup.style.display = "flex";

            document.getElementById(
                "popupTitle"
            ).innerText = "View Book";

            setValues(
                BookId,
                BookName,
                Author,
                Price,
                Pages
            );

            enableInputs(false);

            document.getElementById(
                "submitBtn"
            ).style.display = "none";
        }



        // Set Values

        function setValues(
            BookId,
            BookName,
            Author,
            Price,
            Pages
        ){

            document.getElementById(
                "BookId"
            ).value = BookId;

            document.getElementById(
                "BookName"
            ).value = BookName;

            document.getElementById(
                "Author"
            ).value = Author;

            document.getElementById(
                "Price"
            ).value = Price;

            document.getElementById(
                "Pages"
            ).value = Pages;
        }



        // Enable Disable Inputs

        function enableInputs(flag){

            document.getElementById(
                "BookId"
            ).disabled = !flag;

            document.getElementById(
                "BookName"
            ).disabled = !flag;

            document.getElementById(
                "Author"
            ).disabled = !flag;

            document.getElementById(
                "Price"
            ).disabled = !flag;

            document.getElementById(
                "Pages"
            ).disabled = !flag;
        }



        // Close Popup

        function closePopup(){

            popup.style.display = "none";
        }



        // Add/Edit Book

        form.addEventListener(
            "submit",
            async (e) => {

            e.preventDefault();

            const bookData = {

                BookId:
                    document.getElementById(
                        "BookId"
                    ).value,

                BookName:
                    document.getElementById(
                        "BookName"
                    ).value,

                Author:
                    document.getElementById(
                        "Author"
                    ).value,

                Price:
                    document.getElementById(
                        "Price"
                    ).value,

                Pages:
                    document.getElementById(
                        "Pages"
                    ).value,
            };

            console.log(bookData);
            



            // EDIT

            if(editMode){

                const response = await fetch(
                    `/api/books/${currentBookId}`,
                    {
                        method: "PUT",

                        headers: {
                            "Content-Type":
                            "application/json",
                        },

                        body: JSON.stringify(
                            bookData
                        ),
                    }
                );

                const result =
                    await response.json();

                if(result.Success)alert(result.Success)
                else{
                    alert(result.Error)
                    return;
                }
                
                const row =
                    document.getElementById(
                        `row-${currentBookId}`
                    );

                row.innerHTML = `
                    <td>${bookData.BookId}</td>
                    <td>${bookData.BookName}</td>
                    <td>${bookData.Author}</td>
                    <td>${bookData.Price}</td>
                    <td>${bookData.Pages}</td>

                    <td>

                        <button
                            onclick='openViewPopup(
                                "${bookData.BookId}",
                                "${bookData.BookName}",
                                "${bookData.Author}",
                                "${bookData.Price}",
                                "${bookData.Pages}"
                            )'
                        >
                            View
                        </button>

                        <button
                            onclick='openEditPopup(
                                "${bookData.BookId}",
                                "${bookData.BookName}",
                                "${bookData.Author}",
                                "${bookData.Price}",
                                "${bookData.Pages}"
                            )'
                        >
                            Edit
                        </button>

                        <button
                            onclick='deleteBook(
                                "${bookData.BookId}"
                            )'
                        >
                            Delete
                        </button>

                    </td>
                `;

                  

            }

            // ADD

            else{

                const response = await fetch(
                    "/api/books",
                    {
                        method: "POST",

                        headers: {
                            "Content-Type":
                            "application/json",
                        },

                        body: JSON.stringify(
                            bookData
                        ),
                    }
                );

                const result =
                    await response.json();

                console.log(result);
                if(result.Success)alert(result.Success)
                else{
                    alert(result.Error)
                    return;
                }

                tableBody.innerHTML += `
                    <tr id="row-${bookData.BookId}">

                        <td>${bookData.BookId}</td>
                        <td>${bookData.BookName}</td>
                        <td>${bookData.Author}</td>
                        <td>${bookData.Price}</td>
                        <td>${bookData.Pages}</td>

                        <td>

                            <button
                                onclick='openViewPopup(
                                    "${bookData.BookId}",
                                    "${bookData.BookName}",
                                    "${bookData.Author}",
                                    "${bookData.Price}",
                                    "${bookData.Pages}"
                                )'
                            >
                                View
                            </button>

                            <button
                                onclick='openEditPopup(
                                    "${bookData.BookId}",
                                    "${bookData.BookName}",
                                    "${bookData.Author}",
                                    "${bookData.Price}",
                                    "${bookData.Pages}"
                                )'
                            >
                                Edit
                            </button>

                            <button
                                onclick='deleteBook(
                                    "${bookData.BookId}"
                                )'
                            >
                                Delete
                            </button>

                        </td>

                    </tr>
                `;
            }

            closePopup();
        });



        // Delete Book

        async function deleteBook(BookId){

            const response = await fetch(
                `/api/books/${BookId}`,
                {
                    method: "DELETE",
                }
            );

            const result =
                await response.json();

            console.log(result);
            if(result.Success)alert(result.Success)
            else{
                alert(result.Error)
                return;
            }

            document.getElementById(
                `row-${BookId}`
            ).remove();
        }

    </script>

</body>
</html>