<!DOCTYPE html>
<html>
<head>
    <title>Book Management</title>

    <style>

        body{
            font-family: Arial;
            padding: 20px;
        }

        table{
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th,td{
            border: 1px solid black;
            padding: 10px;
            text-align: center;
        }

        button{
            padding: 6px 12px;
            cursor: pointer;
        }

        .popup{
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);

            justify-content: center;
            align-items: center;
        }

        .popup-content{
            background: white;
            padding: 20px;
            width: 350px;
            border-radius: 10px;
        }

        input{
            width: 100%;
            padding: 8px;
            margin-top: 10px;
        }

        .close-btn{
            float: right;
            background: red;
            color: white;
            border: none;
        }

    </style>
</head>

<body>

    <h1>Book Management</h1>

    <button onclick="openAddPopup()">
        Add Book
    </button>

    <table>

        <thead>

            <tr>

                <th>id</th>
                <th>name</th>
                <th>author</th>
                <th>price</th>
                <th>pages</th>
                <th>Actions</th>

            </tr>

        </thead>

        <tbody id="bookTableBody">

            <% books.forEach((book)=> { %>

                <tr id="row-<%= book.id %>">

                    <td><%= book.id %></td>

                    <td><%= book.name %></td>

                    <td><%= book.author %></td>

                    <td><%= book.price %></td>

                    <td><%= book.pages %></td>

                    <td>

                        <button
                            onclick='openViewPopup(
                                "<%= book.id %>",
                                "<%= book.name %>",
                                "<%= book.author %>",
                                "<%= book.price %>",
                                "<%= book.pages %>"
                            )'
                        >
                            View
                        </button>

                        <button
                            onclick='openEditPopup(
                                "<%= book.id %>",
                                "<%= book.name %>",
                                "<%= book.author %>",
                                "<%= book.price %>",
                                "<%= book.pages %>"
                            )'
                        >
                            Edit
                        </button>

                        <button
                            onclick='deleteBook(
                                "<%= book.id %>"
                            )'
                        >
                            Delete
                        </button>

                    </td>

                </tr>

            <% }) %>

        </tbody>

    </table>



    <!-- Popup -->

    <div class="popup" id="popup">

        <div class="popup-content">

            <button
                class="close-btn"
                onclick="closePopup()"
            >
                X
            </button>

            <h2 id="popupTitle">
                Add Book
            </h2>

            <form id="bookForm">

                <input
                    type="number"
                    id="id"
                    placeholder="Book Id"
                    required
                >

                <input
                    type="text"
                    id="name"
                    placeholder="Book Name"
                    required
                >

                <input
                    type="text"
                    id="author"
                    placeholder="author"
                    required
                >

                <input
                    type="number"
                    id="price"
                    placeholder="price"
                    required
                >

                <input
                    type="number"
                    id="pages"
                    placeholder="pages"
                    required
                >

                <br><br>

                <button type="submit" id="submitBtn">
                    Submit
                </button>

            </form>

        </div>

    </div>



    <script>

        const popup =
            document.getElementById("popup");

        const form =
            document.getElementById("bookForm");

        const tableBody =
            document.getElementById(
                "bookTableBody"
            );

        let editMode = false;

        let currentid = null;



        // Add Popup

        function openAddPopup(){

            popup.style.display = "flex";

            document.getElementById(
                "popupTitle"
            ).innerText = "Add Book";

            form.reset();

            enableInputs(true);

            document.getElementById(
                "submitBtn"
            ).style.display = "block";

            editMode = false;
        }



        // Edit Popup

        function openEditPopup(
            id,
            name,
            author,
            price,
            pages
        ){

            popup.style.display = "flex";

            document.getElementById(
                "popupTitle"
            ).innerText = "Edit Book";

            setValues(
                id,
                name,
                author,
                price,
                pages
            );

            enableInputs(true);

            document.getElementById(
                "submitBtn"
            ).style.display = "block";

            editMode = true;

            currentid = id;
        }



        // View Popup

        function openViewPopup(
            id,
            name,
            author,
            price,
            pages
        ){

            popup.style.display = "flex";

            document.getElementById(
                "popupTitle"
            ).innerText = "View Book";

            setValues(
                id,
                name,
                author,
                price,
                pages
            );

            enableInputs(false);

            document.getElementById(
                "submitBtn"
            ).style.display = "none";
        }



        // Set Values

        function setValues(
            id,
            name,
            author,
            price,
            pages
        ){

            document.getElementById(
                "id"
            ).value = id;

            document.getElementById(
                "name"
            ).value = name;

            document.getElementById(
                "author"
            ).value = author;

            document.getElementById(
                "price"
            ).value = price;

            document.getElementById(
                "pages"
            ).value = pages;
        }



        // Enable Disable Inputs

        function enableInputs(flag){

            document.getElementById(
                "id"
            ).disabled = !flag;

            document.getElementById(
                "name"
            ).disabled = !flag;

            document.getElementById(
                "author"
            ).disabled = !flag;

            document.getElementById(
                "price"
            ).disabled = !flag;

            document.getElementById(
                "pages"
            ).disabled = !flag;
        }



        // Close Popup

        function closePopup(){

            popup.style.display = "none";
        }



        // Add/Edit Book

        form.addEventListener(
            "submit",
            async (e) => {

            e.preventDefault();

            const bookData = {

                id:
                    document.getElementById(
                        "id"
                    ).value,

                name:
                    document.getElementById(
                        "name"
                    ).value,

                author:
                    document.getElementById(
                        "author"
                    ).value,

                price:
                    document.getElementById(
                        "price"
                    ).value,

                pages:
                    document.getElementById(
                        "pages"
                    ).value,
            };

            console.log(bookData);
            



            // EDIT

            if(editMode){

                const response = await fetch(
                    `/api/books/${currentid}`,
                    {
                        method: "PUT",

                        headers: {
                            "Content-Type":
                            "application/json",
                        },

                        body: JSON.stringify(
                            bookData
                        ),
                    }
                );

                const result =
                    await response.json();

                if(result.Success)alert(result.Success)
                else{
                    alert(result.Error)
                    return;
                }
                
                const row =
                    document.getElementById(
                        `row-${currentid}`
                    );

                row.innerHTML = `
                    <td>${bookData.id}</td>
                    <td>${bookData.name}</td>
                    <td>${bookData.author}</td>
                    <td>${bookData.price}</td>
                    <td>${bookData.pages}</td>

                    <td>

                        <button
                            onclick='openViewPopup(
                                "${bookData.id}",
                                "${bookData.name}",
                                "${bookData.author}",
                                "${bookData.price}",
                                "${bookData.pages}"
                            )'
                        >
                            View
                        </button>

                        <button
                            onclick='openEditPopup(
                                "${bookData.id}",
                                "${bookData.name}",
                                "${bookData.author}",
                                "${bookData.price}",
                                "${bookData.pages}"
                            )'
                        >
                            Edit
                        </button>

                        <button
                            onclick='deleteBook(
                                "${bookData.id}"
                            )'
                        >
                            Delete
                        </button>

                    </td>
                `;

                  

            }

            // ADD

            else{

                const response = await fetch(
                    "/api/books",
                    {
                        method: "POST",

                        headers: {
                            "Content-Type":
                            "application/json",
                        },

                        body: JSON.stringify(
                            bookData
                        ),
                    }
                );

                const result =
                    await response.json();

                console.log(result);
                if(result.Success)alert(result.Success)
                else{
                    alert(result.Error)
                    return;
                }

                tableBody.innerHTML += `
                    <tr id="row-${bookData.id}">

                        <td>${bookData.id}</td>
                        <td>${bookData.name}</td>
                        <td>${bookData.author}</td>
                        <td>${bookData.price}</td>
                        <td>${bookData.pages}</td>

                        <td>

                            <button
                                onclick='openViewPopup(
                                    "${bookData.id}",
                                    "${bookData.name}",
                                    "${bookData.author}",
                                    "${bookData.price}",
                                    "${bookData.pages}"
                                )'
                            >
                                View
                            </button>

                            <button
                                onclick='openEditPopup(
                                    "${bookData.id}",
                                    "${bookData.name}",
                                    "${bookData.author}",
                                    "${bookData.price}",
                                    "${bookData.pages}"
                                )'
                            >
                                Edit
                            </button>

                            <button
                                onclick='deleteBook(
                                    "${bookData.id}"
                                )'
                            >
                                Delete
                            </button>

                        </td>

                    </tr>
                `;
            }

            closePopup();
        });



        // Delete Book

        async function deleteBook(id){

            const response = await fetch(
                `/api/books/${id}`,
                {
                    method: "DELETE",
                }
            );

            const result =
                await response.json();

            console.log(result);
            if(result.Success)alert(result.Success)
            else{
                alert(result.Error)
                return;
            }

            document.getElementById(
                `row-${id}`
            ).remove();
        }

    </script>

</body>
</html>